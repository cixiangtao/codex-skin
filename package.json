{
  "name": "codex-skin",
  "version": "1.0.0",
  "description": "An unofficial local appearance companion for the Codex desktop app.",
  "keywords": [
    "codex",
    "desktop",
    "theme",
    "wallpaper"
  ],
  "homepage": "https://github.com/cixiangtao/codex-skin#readme",
  "bugs": {
    "url": "https://github.com/cixiangtao/codex-skin/issues"
  },
  "license": "MIT",
  "author": "anys",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cixiangtao/codex-skin.git"
  },
  "bin": {
    "codex-skin": "dist/bin/codex-skin.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "bun ./bin/codex-skin.ts dev-server",
    "dev:ui": "vp dev --host 127.0.0.1",
    "build": "bun run build:ui && bun run build:runtime",
    "build:runtime": "rm -rf dist/bin && bun build ./bin/codex-skin.ts --target=node --format=esm --outdir=dist/bin",
    "build:ui": "vp build",
    "check": "vp check",
    "format": "vp fmt . --write",
    "lint": "vp lint .",
    "release": "release-it",
    "release:check": "bun run check && bun run test && npm pack --dry-run",
    "test": "vp test run",
    "prepack": "bun run build && bun run verify:package",
    "verify:package": "bun scripts/verify-package.ts"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@locator/babel-jsx": "^0.5.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "release-it": "^20.2.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plus": "^0.2.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.14"
}
