{
  "name": "@anys/codex-background",
  "version": "0.2.0",
  "description": "A visual background companion for the Codex desktop app.",
  "keywords": [
    "codex",
    "desktop",
    "theme",
    "wallpaper"
  ],
  "license": "MIT",
  "author": "anys",
  "bin": {
    "codex-background": "./dist/bin/codex-background.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "bun ./bin/codex-background.ts dev-server",
    "dev:ui": "vp dev --host 127.0.0.1",
    "build": "bun run build:ui && bun run build:runtime",
    "build:runtime": "rm -rf dist/bin && bun build ./bin/codex-background.ts --target=node --format=esm --outdir=dist/bin",
    "build:ui": "vp build",
    "check": "vp check",
    "format": "vp fmt . --write",
    "lint": "vp lint .",
    "test": "vp test run",
    "prepack": "bun run build && bun run verify:package",
    "verify:package": "bun scripts/verify-package.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plus": "^0.2.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.14"
}
