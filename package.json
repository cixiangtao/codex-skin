{
  "name": "@anys/codex-background",
  "version": "0.2.0",
  "description": "A Bun-powered visual background companion for the Codex desktop app.",
  "keywords": [
    "bun",
    "codex",
    "desktop",
    "theme",
    "wallpaper"
  ],
  "license": "MIT",
  "author": "anys",
  "bin": {
    "codex-background": "./bin/codex-background.ts"
  },
  "files": [
    "bin",
    "dist",
    "src/runtime"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:server": "bun ./bin/codex-background.ts dev-server",
    "dev:ui": "vp dev --host 127.0.0.1",
    "build": "vp build",
    "check": "vp check",
    "format": "vp fmt . --write",
    "lint": "vp lint .",
    "test": "vp test run",
    "prepack": "bun run check && bun run build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plus": "^0.2.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
